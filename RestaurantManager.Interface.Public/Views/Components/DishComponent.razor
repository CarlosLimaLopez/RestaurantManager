@using RestaurantManager.Restaurants
@using RestaurantManager.Dishes
@inject IDialogService DialogService

<MudGrid AlignItems="AlignItems.Center" Class="mb-2">

        <MudItem xs="7" Class="mt-2">
        <MudStack Row="true"
                  Spacing="1"
                  Justify="Justify.FlexStart"
                  AlignItems="AlignItems.Center">
            <MudText Class="dish-name" Display="Inline">@DishDto.Name</MudText>
            @if (DishDto.HasImage)
            {
                <MudIconButton Class="mid-icon"
                               Icon=@($"fa-solid fa-eye")
                               OnClick="@(() => PreviewImage(DishDto))" />
            }
        </MudStack>
            
        </MudItem>

        <MudItem xs="4" Class="d-flex justify-end align-center mt-2">
            @if (!string.IsNullOrWhiteSpace(DishDto.Prize))
            {
                <MudText Class="dish-price">@DishDto.Prize</MudText>
            }
        </MudItem>
    


    @if (!string.IsNullOrWhiteSpace(DishDto.Description))
    {
        <MudItem xs="12" Class="pt-0">
                <MudText Class="dish-description">@DishDto.Description</MudText>
        </MudItem>
    }

    @if (DishDto.Allergens.Any())
    {
        <MudItem xs="12" Class="pt-0">
            @foreach (var allergen in DishDto.Allergens)
            {
                <MudIcon Class="small-icon" Size="Size.Small" Icon=@($"fa-solid fa-{allergen.Icon}") Title="@allergen.Name.ToString()" />
            }
        </MudItem>
    }
</MudGrid>

@code {
    [Parameter, EditorRequired]
    public DishGetResponse DishDto { get; set; } = default!;

    [Inject]
    private HttpClient Http { get; set; } = default!;

    private async Task PreviewImage(DishGetResponse dish)
    {
        var options = new DialogOptions()
        {
            CloseButton = false,
            MaxWidth = MaxWidth.Medium,
            FullWidth = false,
            NoHeader = true
        };

        var parameters = new DialogParameters
        {
            { "DishId", $"{dish.DishId}" }
        };

        await DialogService.ShowAsync<ImagePreviewDialog>(null, parameters, options);
    }
}
