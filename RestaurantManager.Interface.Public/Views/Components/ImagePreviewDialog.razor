@inject IDialogService DialogService

<MudDialog Class="image-preview">
    <DialogContent>
        <MudStack AlignItems="AlignItems.Center">
            @if (!string.IsNullOrEmpty(DishId))
            {
                <MudImage Src="@ImageSrc" ObjectFit="ObjectFit.Contain" Style="max-width: 100%; max-height: 500px;" />
            }
            else
            {
                <MudText>No se pudo cargar la imagen</MudText>
            }
        </MudStack>
    </DialogContent>
</MudDialog>

@code {
    [Inject]
    private HttpClient Http { get; set; } = default!;

    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; } = default!;

    private string ImageSrc { get; set; } = string.Empty;

    [Parameter]
    public string DishId { get; set; } = string.Empty;

    protected override async Task OnInitializedAsync()
    {
        var response = await Http.GetAsync($"dishes/{DishId}/image");

        if (response.IsSuccessStatusCode)
        {
            var bytes = await response.Content.ReadAsByteArrayAsync();
            var contentType = response.Content.Headers.ContentType?.MediaType ?? "image/jpeg";
            ImageSrc = $"data:{contentType};base64,{Convert.ToBase64String(bytes)}";
        }
    }
}
