@inject IDialogService DialogService

<MudDialog Class="image-preview">
    <DialogContent>
        <MudStack AlignItems="AlignItems.Center">
            @if (!string.IsNullOrEmpty(ImageUrl))
            {
                <MudImage Src="@ImageUrl" ObjectFit="ObjectFit.Contain" Style="max-width: 100%; max-height: 500px;" />
            }
            else
            {
                <MudText>No se pudo cargar la imagen</MudText>
            }
        </MudStack>
    </DialogContent>
</MudDialog>

@code {
    [CascadingParameter]
    IMudDialogInstance MudDialog { get; set; } = default!;

    [Parameter]
    public string ImageUrl { get; set; } = string.Empty;
}
